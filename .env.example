# FutBot - Configuração de Ambiente

# ========================================
# Google Gemini AI Configuration (OBRIGATÓRIO)
# ========================================

# Google API Key
# Obtenha em: https://aistudio.google.com/apikey
GOOGLE_API_KEY=sua-api-key-do-google-aqui

# ========================================
# Gemini Configuration (OPCIONAL)
# ========================================

# Modelo Gemini a usar (padrão: gemini-2.0-flash-lite)
# Opções: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash-lite

# Ativar busca web integrada (padrão: false)
# Quando true: Gemini busca informações atuais na web
GEMINI_SEARCH_TOOL=false

# ========================================
# Node.js Configuration
# ========================================

# Ambiente da aplicação (padrão: production)
# Valores: development, production
NODE_ENV=production

# ========================================
# Docker Ports Configuration
# ========================================

# Porta do Backend (padrão: 8001)
BACKEND_PORT=8001

# Porta do Frontend (padrão: 3000)
FRONTEND_PORT=3000

# ========================================
# Frontend Configuration
# ========================================

# URL WebSocket para o frontend (padrão: http://127.0.0.1:8081/v1/chat)
# Altere se o backend estiver em outro host
NEXT_PUBLIC_WS_URL=http://127.0.0.1:8081/v1/chat

# WebSocket — Opção 1: URL completa (sobrescreve todas as demais)
NEXT_PUBLIC_WS_URL=http://127.0.0.1:8081/v1/chat

# WebSocket — Opção 2: configurações granulares
# NEXT_PUBLIC_WS_HOST=api.example.com   # padrão: window.location.hostname
# NEXT_PUBLIC_WS_PORT=8001              # padrão: 8001 em localhost, porta atual em outros ambientes
# NEXT_PUBLIC_WS_PATH=/v1/ws/chat      # padrão: /v1/ws/chat
